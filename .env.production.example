# Backend runtime
API_PORT=8002
ADMIN_PORT=8001
BASE_URL=https://forged-ai.posco.example.com
DEBUG=false
LOG_LEVEL=INFO

# Database
MYSQL_HOST=mysql.internal
MYSQL_PORT=3306
MYSQL_USER=xpack
MYSQL_PASSWORD=CHANGE_ME_DB_PASSWORD
MYSQL_DB=xpack
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=600
DB_POOL_PRE_PING=true

# Redis
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0

# RabbitMQ
RABBITMQ_HOST=rabbitmq.internal
RABBITMQ_PORT=5672
RABBITMQ_USER=xpack
RABBITMQ_PASSWORD=CHANGE_ME_RABBITMQ_PASSWORD
RABBITMQ_VHOST=/

# Security and CORS
ALLOWED_ORIGINS=https://forged-ai.posco.example.com,https://admin.forged-ai.posco.example.com
NO_AUTH_PATHS=/,/health,/docs,/openapi.json,/redoc,/api/auth/email/send-captcha,/api/auth/email/sign,/api/auth/account/sign,/api/auth/email/send_captcha,/api/auth/google/sign,/api/web/mcp_tags,/api/web/mcp_services,/api/web/mcp_service_info,/api/payment/callback_stripe
MCP_SESSION_IDLE_TTL_SECONDS=900
MCP_SESSION_CLEANUP_INTERVAL_SECONDS=60

# Email delivery
SMTP_HOST=smtp.posco.example.com
SMTP_PORT=465
SMTP_USER=noreply@posco.example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_SENDER=POSCO Forged AI <noreply@posco.example.com>

# Payment config encryption key
PAYMENT_CONFIG_SECRET_KEY=CHANGE_ME_BASE64_AES_KEY
PAYMENT_CONFIG_KEY_ID=prod-2026-01